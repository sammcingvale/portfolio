# copy this file to .env and fill in your values. .env is gitignored — it never
# gets committed or pushed. nothing here is required for the CSV-import workflow.

# ── SnapTrade (automated daily holdings from Fidelity) ───────────────────────
# get these from your SnapTrade developer dashboard
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# these are produced the first time you run:
#   python ingest/snaptrade_holdings.py --connect
SNAPTRADE_USER_ID=portfolio-owner
SNAPTRADE_USER_SECRET=
