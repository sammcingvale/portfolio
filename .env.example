# copy this file to .env and fill in your values. .env is gitignored — it never
# gets committed or pushed. nothing here is required for the CSV-import workflow.

# ── SnapTrade (automated daily holdings from Fidelity) ───────────────────────
# get these from your SnapTrade dashboard
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# PERSONAL key: the user is auto-provisioned at signup. set USER_ID to that
#   auto-provisioned id and leave USER_SECRET blank — personal keys don't use it
#   (the clientId + consumerKey signature is what authenticates the request).
# DEVELOPER key: both are produced the first time you run:
#   python ingest/snaptrade_holdings.py --connect
SNAPTRADE_USER_ID=portfolio-owner
SNAPTRADE_USER_SECRET=
